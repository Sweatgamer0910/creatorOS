generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ===== Better Auth required tables =====

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions  Session[]
  accounts  Account[]
  workspace Workspace?

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

// ===== CreatorOS app tables =====

model Workspace {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownerId String @unique
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  channels     Channel[]
  ideas        Idea[]
  scripts      Script[]
  contentItems ContentItem[]
  series       Series[]

  @@map("workspace")
}

model Channel {
  id               String   @id @default(cuid())
  youtubeChannelId String   @unique
  title            String
  thumbnailUrl     String?
  connectedAt      DateTime @default(now())

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  snapshots ChannelSnapshot[]

  @@map("channel")
}

model ChannelSnapshot {
  id               String   @id @default(cuid())
  capturedAt       DateTime @default(now())
  subscriberCount  Int
  viewCount        Int
  videoCount       Int
  watchTimeMinutes Int?

  channelId String
  channel   Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@map("channel_snapshot")
}

model Idea {
  id        String   @id @default(cuid())
  title     String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // Optional position within a series — e.g. "Part 3" of an ongoing
  // series. Both null for an idea that isn't part of a series.
  seriesId      String?
  series        Series? @relation(fields: [seriesId], references: [id], onDelete: SetNull)
  episodeNumber Int?

  scripts      Script[]
  contentItems ContentItem[]

  @@map("idea")
}

model Series {
  id          String   @id @default(cuid())
  title       String
  description String?
  // Free-text-ish string, not a Prisma enum — same convention as
  // ContentItem.status/PipelineStatus: a small fixed set of values
  // enforced in TypeScript (see src/lib/series/actions.ts), not the
  // database. "custom" covers anything outside the common presets.
  cadence     String? // daily | weekly | biweekly | custom
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  ideas Idea[]

  @@map("series")
}

model Script {
  id        String   @id @default(cuid())
  title     String
  hook      String   @default("") @db.Text
  intro     String   @default("") @db.Text
  body      String   @default("") @db.Text
  outro     String   @default("") @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Manual per-section completeness — deliberately not inferred from word
  // count (too often wrong), set only by the writer clicking "mark done".
  hookComplete  Boolean @default(false)
  introComplete Boolean @default(false)
  bodyComplete  Boolean @default(false)
  outroComplete Boolean @default(false)

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  ideaId String?
  idea   Idea?   @relation(fields: [ideaId], references: [id], onDelete: SetNull)

  contentItems ContentItem[]
  versions     ScriptVersion[]

  @@map("script")
}

model ScriptVersion {
  id        String   @id @default(cuid())
  hook      String   @db.Text
  intro     String   @db.Text
  body      String   @db.Text
  outro     String   @db.Text
  createdAt DateTime @default(now())

  scriptId String
  script   Script @relation(fields: [scriptId], references: [id], onDelete: Cascade)

  @@map("script_version")
}

model ContentItem {
  id        String    @id @default(cuid())
  title     String
  status    String    @default("idea") // idea | filming | editing | published
  dueDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // Optional trace back to where this card came from — set when a card is
  // created "from" an idea or script rather than typed fresh. Both SetNull
  // so deleting the source idea/script never takes the pipeline card with it.
  ideaId String?
  idea   Idea?   @relation(fields: [ideaId], references: [id], onDelete: SetNull)

  scriptId String?
  script   Script? @relation(fields: [scriptId], references: [id], onDelete: SetNull)

  @@map("content_item")
}
